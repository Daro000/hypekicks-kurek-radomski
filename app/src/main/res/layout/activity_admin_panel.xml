<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212">


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔐 Panel Administratora"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DODAJ NOWEGO BUTA"
        android:textColor="#FF6B35"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editBrand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Marka (np. Nike, Adidas)"
        android:backgroundTint="#444444"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/editModelName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Model (np. Air Jordan 1 Retro High OG)"
        android:backgroundTint="#444444"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:layout_marginBottom="6dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <EditText
            android:id="@+id/editReleaseYear"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Rok (np. 2024)"
            android:inputType="number"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/editResellPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Cena resell (PLN)"
            android:inputType="numberDecimal"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"
            android:textColorHint="#888888"/>

    </LinearLayout>

    <EditText
        android:id="@+id/editImageUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="URL zdjęcia (link z postimages.org)"
        android:backgroundTint="#444444"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnAddSneaker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➕ DODAJ DO BAZY"
        android:backgroundTint="#FF6B35"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>


    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="12dp"/>


    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LISTA BUTÓW W MAGAZYNIE"
        android:textColor="#FF6B35"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Przytrzymaj but, aby usunąć | Kliknij, aby edytować cenę"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/listViewSneakers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#222222"
        android:dividerHeight="1dp"/>

</LinearLayout>